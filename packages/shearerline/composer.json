{
    "name": "shearerline/shearerline",
    "description": "Shearerline - 在线课程教务系统商品成本计算与结算分账扩展包",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shearerline",
            "email": "support@shearerline.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/database": "^9.0|^10.0|^11.0",
        "illuminate/validation": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Shearerline\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Shearerline\\Tests\\": "src/Tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shearerline\\ShearerlineServiceProvider"
            ],
            "aliases": {
                "Shearerline": "Shearerline\\Facades\\Shearerline"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
